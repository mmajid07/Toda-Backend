{
  "family": "todo-app-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "todo-redis",
      "image": "redis:7-alpine",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 6379,
          "hostPort": 6379,
          "protocol": "tcp"
        }
      ],
      "command": ["redis-server", "--appendonly", "yes"],
      "healthCheck": {
        "command": ["CMD-SHELL", "redis-cli ping || exit 1"],
        "interval": 10,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/todo-app",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "redis"
        }
      }
    },
    {
      "name": "todo-app-service",
      "image": "400024183686.dkr.ecr.us-east-1.amazonaws.com/todo-app:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3005,
          "hostPort": 3005,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",    "value": "production" },
        { "name": "PORT",        "value": "3005" },
        { "name": "REDIS_HOST",  "value": "localhost" },
        { "name": "REDIS_PORT",  "value": "6379" },
        { "name": "SESSION_SECRET", "value": "change-this-secret-in-production" }
      ],
      "dependsOn": [
        {
          "containerName": "todo-redis",
          "condition": "HEALTHY"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3005/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/todo-app",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "app"
        }
      }
    }
  ],
  "executionRoleArn": "arn:aws:iam::400024183686:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::400024183686:role/ecsTaskRole"
}
